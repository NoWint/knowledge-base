{
  "calculationTypes": [
    {
      "id": "calc-type-1",
      "category": "化学式计算",
      "title": "化学式的基本计算",
      "formulas": [
        "相对分子质量 = 各原子相对原子质量×原子个数之和",
        "元素质量比 = 各元素相对原子质量×原子个数之比",
        "元素质量分数 = (元素相对原子质量×原子个数) / 相对分子质量 × 100%"
      ],
      "examples": [
        {
          "question": "计算H₂O的相对分子质量和氧元素的质量分数",
          "solution": [
            "相对分子质量 = 1×2 + 16×1 = 18",
            "氧元素质量分数 = 16/18 × 100% = 88.9%"
          ]
        },
        {
          "question": "计算CO₂中C、O元素的质量比",
          "solution": ["C:O = 12:32 = 3:8"]
        },
        {
          "question": "多少克水中含氧8克？",
          "solution": [
            "设需要水的质量为x",
            "x × (16/18) × 100% = 8g",
            "x = 9g"
          ]
        }
      ]
    },
    {
      "id": "calc-type-2",
      "category": "化学方程式计算",
      "title": "根据化学方程式的计算",
      "steps": [
        "写：写出正确的化学方程式",
        "标：标出已知量和未知量",
        "列：列出比例式",
        "求：求解",
        "答：写出答案"
      ],
      "example": {
        "question": "加热分解12.25g氯酸钾，可得到氧气多少克？",
        "equation": "2KClO₃ ==MnO₂/加热== 2KCl + 3O₂↑",
        "solution": [
          "设：可得到氧气质量为x",
          "2KClO₃ ==MnO₂/加热== 2KCl + 3O₂↑",
          "245 ----------------------------- 96",
          "12.25g ----------------------------- x",
          "245/12.25 = 96/x",
          "x = 12.25 × 96 / 245 = 4.8g"
        ],
        "notes": [
          "化学方程式必须配平",
          "单位要统一",
          "纯物质质量才能代入比例",
          "体积要换算成质量"
        ]
      }
    },
    {
      "id": "calc-type-3",
      "category": "化学方程式计算",
      "title": "含杂质的计算",
      "method": "先换算纯物质质量，再代入比例计算",
      "formula": "纯物质质量 = 不纯物质质量 × 纯度",
      "examples": [
        {
          "question": "含杂质20%的石灰石100g，完全分解能得到CO₂多少克？",
          "equation": "CaCO₃ ==高温== CaO + CO₂↑",
          "solution": [
            "纯CaCO₃质量 = 100g × (1-20%) = 80g",
            "设生成CO₂质量为x",
            "CaCO₃ ==高温== CaO + CO₂↑",
            "100 ------------------- 44",
            "80g -------------------- x",
            "100/80 = 44/x",
            "x = 80 × 44 / 100 = 35.2g"
          ]
        }
      ]
    },
    {
      "id": "calc-type-4",
      "category": "溶液计算",
      "title": "溶质质量分数的计算",
      "formulas": [
        "溶质质量分数 = 溶质质量 / 溶液质量 × 100%",
        "溶液质量 = 溶质质量 + 溶剂质量",
        "溶液质量 = 溶液体积 × 溶液密度"
      ],
      "examples": [
        {
          "question": "将20g NaCl溶于80g水中，求所得溶液的溶质质量分数",
          "solution": ["溶质质量分数 = 20/(20+80) × 100% = 20%"]
        },
        {
          "question": "配制500mL 20%的稀硫酸（密度1.14g/mL），需要浓硫酸（98%，密度1.84g/mL）多少毫升？水多少毫升？",
          "solution": [
            "稀硫酸质量 = 500 × 1.14 = 570g",
            "其中纯H₂SO₄质量 = 570 × 20% = 114g",
            "需浓硫酸体积 = 114 / (98% × 1.84) = 63.2mL",
            "需水的质量 = 570 - 114 = 456g",
            "需水的体积 = 456 / 1 = 456mL"
          ]
        }
      ]
    },
    {
      "id": "calc-type-5",
      "category": "溶液计算",
      "title": "溶液稀释和混合的计算",
      "formulas": [
        "稀释前溶质质量 = 稀释后溶质质量",
        "稀释前溶液质量 × 稀释前质量分数 = 稀释后溶液质量 × 稀释后质量分数",
        "m₁ × a% + m₂ × b% = (m₁ + m₂) × c%（两种溶液混合）"
      ],
      "examples": [
        {
          "question": "将100g 98%的浓硫酸配制成20%的稀硫酸，需要加水多少克？",
          "solution": [
            "设需加水质量为x",
            "100 × 98% = (100 + x) × 20%",
            "98 = 20 + 0.2x",
            "x = 390g"
          ]
        }
      ]
    },
    {
      "id": "calc-type-6",
      "category": "溶液计算",
      "title": "溶解度的计算",
      "formulas": [
        "溶解度 = (饱和溶液中溶质质量 / 溶剂质量) × 100g",
        "饱和溶液中：溶质质量分数 = 溶解度 / (100 + 溶解度) × 100%"
      ],
      "examples": [
        {
          "question": "20°C时，KNO₃的溶解度为31.6g。求此温度下KNO₃饱和溶液的溶质质量分数。",
          "solution": [
            "溶质质量分数 = 31.6 / (100 + 31.6) × 100%",
            "= 24%"
          ]
        }
      ]
    },
    {
      "id": "calc-type-7",
      "category": "化学方程式计算",
      "title": "气体体积与质量的换算",
      "formula": "气体质量 = 气体体积(L) / 22.4(L/mol) × 摩尔质量(g/mol)",
      "conditions": "标准状况下（0°C，101kPa）",
      "examples": [
        {
          "question": "标准状况下，33.6L CO₂的质量是多少克？",
          "solution": [
            "CO₂的摩尔质量 = 44g/mol",
            "CO₂的物质的量 = 33.6 / 22.4 = 1.5mol",
            "质量 = 1.5 × 44 = 66g"
          ]
        }
      ]
    },
    {
      "id": "calc-type-8",
      "category": "化学方程式计算",
      "title": "多步反应计算",
      "method": "找出关系式，一步计算",
      "examples": [
        {
          "question": "多少克碳完全燃烧能得到44g CO₂？",
          "equation": "C + O₂ ==点燃== CO₂",
          "solution": [
            "关系式：C ~ CO₂",
            "C原子守恒：1mol C → 1mol CO₂",
            "12g C → 44g CO₂",
            "设需碳质量为x",
            "12/44 = x/44",
            "x = 12g"
          ]
        }
      ]
    },
    {
      "id": "calc-type-9",
      "category": "化学方程式计算",
      "title": "利用质量差求反应物或生成物质量",
      "principle": "化学反应中，物质质量守恒，差量法是常用的解题技巧",
      "formula": "生成物质量 - 反应物质量 = 气体或沉淀质量",
      "examples": [
        {
          "question": "6g铁与足量稀硫酸反应，生成氢气多少克？反应后溶液质量增加多少？",
          "solution": [
            "Fe + H₂SO₄ = FeSO₄ + H₂↑",
            "56g ------------------- 2g --- 溶液增重54g",
            "6g -------------------- x ----- y",
            "x = 6 × 2 / 56 = 0.214g",
            "y = 6 × 54 / 56 = 5.79g"
          ]
        }
      ]
    },
    {
      "id": "calc-type-10",
      "category": "推断题计算",
      "title": "化合物中元素质量分数的比较",
      "method": "比较元素质量分数时，只需比较该元素的相对原子质量与原子个数的比值",
      "examples": [
        {
          "question": "比较Fe₂O₃和Fe₃O₄中铁元素的质量分数",
          "solution": [
            "Fe₂O₃：Fe:O = (56×2):(16×3) = 112:48",
            "Fe₃O₄：Fe:O = (56×3):(16×4) = 168:64",
            "换算成相同氧原子：",
            "Fe₂O₃：Fe:O = 112:48 = 224:96",
            "Fe₃O₄：Fe:O = 168:64 = 252:96",
            "所以Fe₃O₄中铁元素质量分数更大"
          ]
        }
      ]
    },
    {
      "id": "calc-type-11",
      "category": "综合计算",
      "title": "综合计算解题思路",
      "steps": [
        "认真审题，明确已知条件和求解问题",
        "写出相关反应的化学方程式",
        "分析已知量与求解量的关系",
        "正确写出比例式",
        "仔细计算，确保准确",
        "检查答案是否符合化学原理"
      ],
      "commonMistakes": [
        "化学方程式没有配平",
        "单位不统一",
        "纯物质和含杂质物质混淆",
        "把不纯物质的质量直接代入比例",
        "计算粗心大意"
      ]
    }
  ]
}