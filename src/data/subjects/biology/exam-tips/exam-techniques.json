            "判断遗传方式（显性/隐性、常染色体/性染色体）",
            "推导相关个体的基因型",
            "计算后代表型概率",
            "书写遗传图解"
          ]
        },
        {
          "name": "生态系统综合题",
          "features": "综合考查生态平衡、物质循环、能量流动",
          "strategy": [
            "识别生态系统的各组成成分",
            "分析食物链和食物网",
            "判断能量流动特点",
            "理解物质循环途径"
          ]
        }
      ],
      "答题要点": [
        "用准确的生物学术语表述",
        "逻辑清晰，条理分明",
        "不要留空，确保完整作答",
        "注意书写规范"
      ]
    }
  }
